<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Reminder: Pending Document Upload</title>
  </head>
  <body
    style="
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    "
  >
    <div style="text-align: center; margin-bottom: 24px">
      <h2 style="color: #1c3260; margin-bottom: 4px">
        Reminder - Your Photos & Videos Haven't Uploaded Yet.
      </h2>
    </div>

    <div>
      <p
        style="
          font-size: 16px;
          font-weight: bold;
          margin-top: 0;
          margin-bottom: 16px;
          color: #333;
        "
      >
        Dear <%= recipientName %>,
      </p>

      <p style="font-size: 14px; color: #555; margin-bottom: 24px">
        This is a friendly reminder that we are still waiting for the required
        document uploads for the submission details outlined below.
      </p>

      <!-- Details Card matching style of uploadReminder.ejs -->
      <div
        style="
          background-color: #f8fafc;
          border: 1px solid #e2e8f0;
          border-radius: 6px;
          padding: 20px;
          margin-bottom: 28px;
        "
      >
        <h3
          style="
            color: #1c3260;
            margin-top: 0;
            margin-bottom: 16px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
          "
        >
          Submission Details
        </h3>

        <p style="margin: 8px 0; font-size: 14px; color: #555">
          <strong style="color: #333">Form Name:</strong> <%= formName %>
        </p>
        <p style="margin: 8px 0; font-size: 14px; color: #555">
          <strong style="color: #333">Property:</strong> <%= propertyName %>
        </p>
        <p style="margin: 8px 0; font-size: 14px; color: #555">
          <strong style="color: #333">Unit:</strong> <%= unitName %>
        </p>
      </div>

      <p style="font-size: 14px; color: #555; margin-bottom: 24px">
        To prevent any delays in processing, please click the button below to
        securely connect and complete your pending file uploads.
      </p>

      <% if (typeof uploadLink !== 'undefined' && uploadLink) { %>
      <!-- CTA Button matching style of uploadReminder.ejs -->
      <div style="text-align: center; margin-top: 32px; margin-bottom: 16px">
        <a
          href="<%= uploadLink %>"
          style="
            background-color: #1c3260;
            color: #ffffff;
            padding: 12px 24px;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            display: inline-block;
          "
        >
          Upload Files Now
        </a>
      </div>

      <div style="text-align: center; margin-top: 16px; margin-bottom: 24px">
        <p
          style="font-size: 12px; color: #666; word-break: break-all; margin: 0"
        >
          If the button above does not work, copy and paste this link into your
          browser:<br />
          <a
            href="<%= uploadLink %>"
            style="color: #1c3260; text-decoration: underline"
            ><%= uploadLink %></a
          >
        </p>
      </div>
      <% } %>
    </div>

    <!-- Footer matching style of uploadReminder.ejs and original layout -->
    <div style="margin-top: 40px; padding-top: 20px">
      <p>Sincerely,</p>
      <p>Premium Property</p>
      <!-- <p style="font-size: 11px; color: #94a3b8; line-height: 1.5; margin: 0;">
            This is an automated request portal from Premium Property. Please do not reply directly to this email.<br/>
            If you have already uploaded these documents, you can safely ignore this automated reminder.
        </p> -->
    </div>
  </body>
</html>
