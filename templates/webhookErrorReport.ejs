<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Daily Webhook Error Report - <%= dateStr %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        margin: 0 auto;
        padding: 20px;
      }
      .section-title {
        color: #1c3260;
        margin-bottom: 5px;
        border-bottom: 2px solid #1c3260;
        padding-bottom: 5px;
      }
      .error-text {
        color: #c62828;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <div style="margin-bottom: 24px">
      <h2 style="color: #1c3260; margin-bottom: 4px">
        Daily Webhook Error Report (<%= dateStr %>)
      </h2>
      <p>
        Found <strong class="error-text"><%= errorCount %></strong> webhook errors in the past 24 hours.
      </p>
      <p>
        <strong>A detailed Excel report containing the error logs is attached to this email.</strong>
      </p>
    </div>
  </body>
</html>
